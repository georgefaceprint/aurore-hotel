rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms & Amenities: public read, admin write only ──
    match /rooms/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'faceprint@icloud.com';
    }
    match /amenities/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'faceprint@icloud.com';
    }

    // ── Reservations: guests can create, admin can read/update all ──
    match /reservations/{id} {
      allow create: if true;
      allow read: if request.auth != null &&
        (request.auth.token.email == 'faceprint@icloud.com' ||
         resource.data.userId == request.auth.uid);
      allow update, delete: if request.auth != null && request.auth.token.email == 'faceprint@icloud.com';
    }

    // ── Chat messages: anyone can read/write (guest widget) ──
    match /messages/{id} {
      allow read, write: if true;
    }

    // ── Employees: admin only ──
    match /employees/{id} {
      allow read, write: if request.auth != null && request.auth.token.email == 'faceprint@icloud.com';
    }
  }
}
